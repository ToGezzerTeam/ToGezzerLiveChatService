# Server
PORT=3000
LOG_LEVELS=verbose,debug,log,warn,error,fatal

# WebSocket
WS_CORS_ORIGIN=*

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=message.exchange
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_ROUTING_KEY=routing-message-live-chat-service
RABBITMQ_MESSAGE_QUEUE=live-chat-service-queue
