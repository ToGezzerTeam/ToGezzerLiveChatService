# Server
PORT=3000
LOG_LEVELS=verbose,debug,log,warn,error,fatal

# WebSocket
WS_CORS_ORIGIN=*

# Auth (JWT)
JWT_SECRET=0123456789abcdef0123456789abcdef
JWT_ISSUER=
JWT_AUDIENCE=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_MESSAGE_QUEUE=ws_messages
